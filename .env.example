
# Get a free key at https://rapidapi.com — subscribe to the JSearch API
RAPIDAPI_KEY=your_rapidapi_key_here

# Gmail address to send the report from
SENDER_EMAIL=you@gmail.com

# Gmail App Password (not your regular password).
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2-factor authentication to be enabled on your account.
SENDER_PASSWORD=your_16_character_app_password

# Optional: recipient address (defaults to SENDER_EMAIL if omitted)
# RECIPIENT_EMAIL=someone_else@gmail.com
